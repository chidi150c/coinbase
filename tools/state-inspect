cat > ~/coinbase/monitoring/what-state <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${STATE_FILE:-/opt/coinbase/state/bot_state.newbinance.json}"
MODE=""
N=1
COMPACT=false
REASON=false

usage() {
  cat <<USAGE
Usage:
  what-state --buy|--sell|--exit|--all [options]

Options:
  --buy             Show latest BUY lots
  --sell            Show latest SELL lots
  --exit            Show latest exits
  --all             Show BUY, SELL, and EXIT
  -n, --n NUM       Number of items to show, default: 1
  --compact         Print one-line compact output
  --reason          Print only key fields plus reason
  -f, --file PATH   State file path
  -h, --help        Show this help

Examples:
  what-state --buy
  what-state --sell -n 3
  what-state --exit --compact
  what-state --all --reason
  what-state --all --compact --n 10
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --buy) MODE="buy"; shift ;;
    --sell) MODE="sell"; shift ;;
    --exit) MODE="exit"; shift ;;
    --all) MODE="all"; shift ;;
    -n|--n) N="${2:-}"; shift 2 ;;
    --compact) COMPACT=true; shift ;;
    --reason) REASON=true; shift ;;
    -f|--file) STATE_FILE="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown arg: $1"; usage; exit 1 ;;
  esac
done

[[ -n "$MODE" ]] || { usage; exit 1; }
[[ "$N" =~ ^[0-9]+$ ]] || { echo "Invalid -n/--n: $N"; exit 1; }
[[ -f "$STATE_FILE" ]] || { echo "State file not found: $STATE_FILE"; exit 1; }

print_items() {
  local path="$1"
  local title="$2"

  echo "=== $title last $N ==="

  if [[ "$COMPACT" == true ]]; then
    jq -r --argjson n "$N" --arg title "$title" '
      def cdt:
        if . == null then "n/a"
        else
          sub("\\.[0-9]+Z$"; "Z")
          | fromdateiso8601
          | . - (5*3600)
          | strftime("%Y-%m-%d %H:%M:%S CDT")
        end;

      def num:
        if . == null then null else (try tonumber catch null) end;

      def exit_part:
        ((.reason // .Reason // "") | capture("exitReason\\{(?<x>.*)\\} \\| openReason\\{")? | .x)
        // (.reason // .Reason // "");

      def open_part:
        ((.reason // .Reason // "") | capture("openReason\\{(?<x>.*)\\}$")? | .x)
        // (.reason // .Reason // "");

      def pup:
        if $title == "EXIT" then
          (exit_part | capture("pUp=(?<x>[0-9.]+)")? | .x) // "n/a"
        else
          (open_part | capture("pUp=(?<x>[0-9.]+)")? | .x) // "n/a"
        end;

      def conf:
        if $title == "EXIT" then
          (exit_part | capture("confidence=(?<x>[0-9.]+)")? | .x)
          // (.confidence_mult // .ConfidenceMult // "n/a")
        else
          (open_part | capture("confidence=(?<x>[0-9.]+)")? | .x)
          // (.confidence_mult // .ConfidenceMult // "n/a")
        end;

      def final_sig:
        if $title == "EXIT" then
          (exit_part | capture("final=(?<x>BUY|SELL|FLAT)")? | .x) // "n/a"
        else
          (open_part | capture("final=(?<x>BUY|SELL|FLAT)")? | .x) // "n/a"
        end;

      def reason_type:
        ((.reason // .Reason // "") | split(" | ")[0] | split("|")[0]) // "n/a";

      def open_notional:
        (.OpenNotionalUSD // .open_notional_usd)
        // (
          ((.OpenPrice // .open_price) | num) as $open
          | ((.SizeBase // .size_base // .size // .Size) | num) as $size
          | if $open != null and $size != null then ($open * $size)
            else null
            end
        )
        // (
          (.side // .Side // "") as $side
          | (.open_price // .OpenPrice | num) as $open
          | (.close_price // .ClosePrice | num) as $close
          | (.pnl_usd // .PnLUSD | num) as $pnl
          | if $open == null or $close == null or $pnl == null or $open == $close then null
            elif $side == "BUY" then
              ($pnl / ($close - $open)) as $size
              | ($open * ($size | fabs))
            elif $side == "SELL" then
              ($pnl / ($open - $close)) as $size
              | ($open * ($size | fabs))
            else null
            end
        )
        // "n/a";

      def unrealized_pnl:
        (.unrealized_pnl_usd // .UnrealizedPnLUSD // "n/a");

      '"$path"' // []
      | .[-$n:]
      | reverse
      | .[]
      | if $title == "EXIT" then
          "time=\(.time|cdt) side=\(.side // "n/a") reason=\(reason_type) pUp=\(pup) conf=\(conf) d_signal=\(final_sig) pnl=\(.pnl_usd // 0) open_notional_usd=\(open_notional) size=\(.size_base // "n/a") open=\(.open_price // 0) close=\(.close_price // 0) exit_mode=\(.exit_mode // "n/a") entry_id=\(.entry_order_id // "n/a") exit_id=\(.exit_order_id // "n/a")"
        else
          "time=\(.OpenTime|cdt) side=\(.Side // "n/a") lot_id=\(.lot_id // .LotID // "n/a") open=\(.OpenPrice // 0) size=\(.SizeBase // 0) open_notional_usd=\(open_notional) unrealized_pnl_usd=\(unrealized_pnl) pUp=\(pup) conf=\(conf) net_gate_usd=\(.profit_gate_usd // .ProfitGateUSD // "n/a") entry_id=\(.entry_order_id // .EntryOrderID // "n/a")"
        end
    ' "$STATE_FILE"

  elif [[ "$REASON" == true ]]; then
    jq --argjson n "$N" "$path // [] | .[-\$n:] | reverse | .[] | {
      time:(.OpenTime // .time),
      side:(.Side // .side),
      lot_id:(.lot_id // .LotID),
      open:(.OpenPrice // .open_price),
      close:.close_price,
      size_base:(.SizeBase // .size_base),
      pnl:.pnl_usd,
      open_notional_usd:(.OpenNotionalUSD // .open_notional_usd),
      unrealized_pnl_usd:(.unrealized_pnl_usd // .UnrealizedPnLUSD),
      entry_order_id:(.entry_order_id // .EntryOrderID),
      exit_order_id:.exit_order_id,
      exit_mode:.exit_mode,
      reason:(.reason // .Reason)
    }" "$STATE_FILE"

  else
    jq --argjson n "$N" "$path // [] | .[-\$n:] | reverse | .[]" "$STATE_FILE"
  fi
}

case "$MODE" in
  buy) print_items ".BookBuy.lots" "BUY" ;;
  sell) print_items ".BookSell.lots" "SELL" ;;
  exit) print_items ".Exits" "EXIT" ;;
  all)
    print_items ".BookBuy.lots" "BUY"
    print_items ".BookSell.lots" "SELL"
    print_items ".Exits" "EXIT"
    ;;
esac
EOF

chmod +x ~/coinbase/monitoring/what-state
sudo ln -sf ~/coinbase/monitoring/what-state /usr/local/bin/what-state

