cat > ~/coinbase/monitoring/what-case <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="${LOG_FILE:-/opt/coinbase/logs/audit/binance_audit.log}"
HOURS="${HOURS:-48}"
CSV=false
N=""

usage() {
  cat <<USAGE
Usage:
  what-case [options]

Options:
  --csv             Output CSV
  -n, --n NUM       Limit output rows
  --hours NUM       Lookback hours, default: 48
  -f, --file PATH   Audit log path
  -h, --help        Show help

Examples:
  what-case
  what-case --csv > case1.csv
  what-case --hours 24
  what-case --csv --hours 48 > case1.csv
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --csv) CSV=true; shift ;;
    -n|--n) N="${2:-}"; shift 2 ;;
    --hours) HOURS="${2:-}"; shift 2 ;;
    -f|--file) LOG_FILE="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown arg: $1"; usage; exit 1 ;;
  esac
done

[[ -f "$LOG_FILE" ]] || { echo "Log file not found: $LOG_FILE"; exit 1; }
[[ "$HOURS" =~ ^[0-9]+$ ]] || { echo "Invalid --hours: $HOURS"; exit 1; }
[[ -z "$N" || "$N" =~ ^[0-9]+$ ]] || { echo "Invalid -n/--n: $N"; exit 1; }

awk -v since="$(date -u -d "$HOURS hours ago" +%s)" -v csv="$CSV" -v limit="$N" '
function ts_epoch(line, a) {
  if (match(line, /[0-9]{4}\/[0-9]{2}\/[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}/)) {
    split(substr(line,RSTART,19), a, /[\/ :]/)
    return mktime(a[1]" "a[2]" "a[3]" "a[4]" "a[5]" "a[6])
  }
  return 0
}

function dist(raw, p, b, s) {
  if (raw == "BUY" && p != "" && b != "") return sprintf("%.5f", p - b)
  if (raw == "SELL" && p != "" && s != "") return sprintf("%.5f", p - s)
  return ""
}

BEGIN {
  if (csv == "true") {
    print "prev_time,curr_time,transition,prev_pUp,curr_pUp,buyTh,sellTh,dist,confidence,logicOpinion,final,prev_price,curr_price,price_diff"
  } else {
    printf "%-20s %-20s %-12s %-9s %-9s %-9s %-9s %-10s %-10s %-12s %-8s %-14s %-14s %-10s\n", \
      "prev_time","curr_time","transition","prev_pUp","curr_pUp","buyTh","sellTh","dist","conf","logic","final","prev_price","curr_price","price_diff"
  }
}

{
  e = ts_epoch($0)
  if (e && e < since) next

  aiRaw = pUp = buyTh = sellTh = price = t = conf = logic = final = ""

  if (match($0, /aiRaw=(BUY|SELL|FLAT)/)) aiRaw = substr($0, RSTART+6, RLENGTH-6)
  if (match($0, /pUp=[0-9.]+/)) pUp = substr($0, RSTART+4, RLENGTH-4)
  if (match($0, /modelBuyThresh=[0-9.]+/)) buyTh = substr($0, RSTART+15, RLENGTH-15)
  if (match($0, /modelSellThresh=[0-9.]+/)) sellTh = substr($0, RSTART+16, RLENGTH-16)
  if (match($0, /price=[0-9.]+/)) price = substr($0, RSTART+6, RLENGTH-6)
  if (match($0, /confidence=[0-9.]+/)) conf = substr($0, RSTART+11, RLENGTH-11)
  if (match($0, /logicOpinion=(BUY|SELL|FLAT)/)) logic = substr($0, RSTART+13, RLENGTH-13)
  if (match($0, /final=(BUY|SELL|FLAT)/)) final = substr($0, RSTART+6, RLENGTH-6)
  if (match($0, /[0-9]{4}\/[0-9]{2}\/[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}/)) t = substr($0, RSTART, RLENGTH)

  if (aiRaw != "" && previousAIRaw == "FLAT" && (aiRaw == "BUY" || aiRaw == "SELL")) {
    cd = dist(aiRaw, pUp, buyTh, sellTh)

    if (prevPrice != "" && price != "") {
      priceDiff = sprintf("%.2f", price - prevPrice)
    } else {
      priceDiff = ""
    }

    rows++

    if (csv == "true") {
      print prevTime "," t "," previousAIRaw "->" aiRaw "," prevPUp "," pUp "," buyTh "," sellTh "," cd "," conf "," logic "," final "," prevPrice "," price "," priceDiff
    } else {
      printf "%-20s %-20s %-12s %-9s %-9s %-9s %-9s %-10s %-10s %-12s %-8s %-14s %-14s %-10s\n", \
        prevTime, t, previousAIRaw "->" aiRaw, prevPUp, pUp, buyTh, sellTh, cd, conf, logic, final, prevPrice, price, priceDiff
    }

    if (limit != "" && rows >= limit) exit
  }

  if (aiRaw != "") {
    previousAIRaw = aiRaw
    prevTime = t
    prevPUp = pUp
    prevBuyTh = buyTh
    prevSellTh = sellTh
    prevPrice = price
  }
}
' "$LOG_FILE"
EOF

chmod +x ~/coinbase/monitoring/what-case
